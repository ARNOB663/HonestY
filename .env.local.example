# Copy this file to .env.local and fill in your own values.
# Never commit .env.local — it holds real secrets. This .example file must
# contain placeholders only.

# ── Database ────────────────────────────────────────────────────────────────
# MongoDB connection string.
#   Local:  mongodb://127.0.0.1:27017/honesty
#   Atlas:  mongodb+srv://USER:PASS@cluster.mongodb.net/honesty
MONGODB_URI=

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
# In production set this to your real https domain, e.g. https://honesty.com.bd
NEXTAUTH_URL=https://honest-y-git-development-arnob663s-projects.vercel.app/

# Auto-admin emails (the "owners"). Comma-separated:
#   ADMIN_EMAIL=alice@example.com,bob@example.com
# Separators are forgiving: `,` `;` `|` or whitespace all work.
#
# Two-tier admin system:
#   1. ADMIN_EMAIL (this var)  -> hardcoded owners; survive DB resets; can't
#      be removed via the admin UI. Keep YOUR personal email here.
#   2. Admin panel -> Staff    -> day-to-day team members stored in Mongo;
#      add/remove/promote/demote live without touching env or redeploying.
#
# Best practice: keep only the owner email(s) here, add everyone else via
# the Staff page so you can revoke them in 2 clicks.
ADMIN_EMAIL=you@example.com

# ── Google OAuth (optional) ──────────────────────────────────────────────────
# Only needed for the "Continue with Google" button. Leave blank to disable.
# Create credentials: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://your-domain/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Cloudinary (image uploads) ───────────────────────────────────────────────
# Find these at https://cloudinary.com/console (cloud name is case-sensitive).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email / SMTP (optional) ──────────────────────────────────────────────────
# For order confirmations, status updates, and password resets.
# Leave blank and the app still works — it just won't send email.
# Gmail: enable 2-Step Verification, then create an App Password at
#        https://myaccount.google.com/apppasswords (spaces in the password are OK).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Public store name used in email subjects/headers.
NEXT_PUBLIC_STORE_NAME=Honesty

# ── Upstash Redis (optional, recommended for Vercel) ─────────────────────────
# Powers rate limiting across all serverless instances. Without these, rate
# limiting still works but only per-instance (much weaker against attackers).
# Easiest setup: Vercel dashboard → Storage → Upstash Redis → Add. It auto-
# injects both vars and you don't have to set them manually.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# NOTE: bKash / Nagad merchant numbers and on/off toggles are configured in the
# admin panel (Settings → Payment), NOT here.

