# Copy to .env.local and fill in real values.
# DO NOT commit .env.local — it's gitignored.

# ── Database ────────────────────────────────────────────────────────────
# MySQL 8+ connection string used by Prisma.
# Local dev example: mysql://root@localhost:3306/honesty_dev
# cPanel example:    mysql://cpanel_user:cpanel_pass@localhost:3306/cpanel_db
DATABASE_URL=

# ── NextAuth ────────────────────────────────────────────────────────────
# Generate a strong secret: `openssl rand -base64 32`
NEXTAUTH_SECRET=
# Public origin of the deployed app.
NEXTAUTH_URL=http://localhost:3000

# ── Admin access ────────────────────────────────────────────────────────
# Comma-separated list of emails that are treated as admins on sign-in.
# These take precedence over the DB `role` column.
ADMIN_EMAIL=

# ── Google OAuth ────────────────────────────────────────────────────────
# Redirect URI to whitelist in Google Cloud:
#   {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── SMTP (transactional + admin emails) ─────────────────────────────────
# Gmail tested. For Gmail use an App Password, not your account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HonestY <no-reply@example.com>"

# ── Cloudinary (product images) ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
